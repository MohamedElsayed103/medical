# ───────────────────────────────────────────
# Healthcare SaaS — Environment Variables
# Copy to .env and fill in real values.
# ───────────────────────────────────────────

# ── Django ──
SECRET_KEY=change-me-to-a-random-64-char-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL 16) ──
DB_NAME=healthcare
DB_USER=healthcare_user
DB_PASSWORD=healthcare_pass
DB_HOST=db
DB_PORT=5432

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── RabbitMQ ──
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ── MinIO (S3-compatible) ──
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ENDPOINT_URL=http://minio:9000
MINIO_BUCKET_DOCUMENTS=medical-documents
MINIO_BUCKET_AI_INPUTS=ai-inputs
MINIO_REGION=us-east-1
MINIO_USE_SSL=False
MINIO_VERIFY_SSL=False

# ── Keycloak ──
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=healthcare-saas
OIDC_RP_CLIENT_ID=web-app
OIDC_RP_CLIENT_SECRET=change-me

# ── AI Service ──
AI_SERVICE_BASE_URL=http://ai-service:5000
AI_SERVICE_TIMEOUT=30

# ── Encryption ──
FIELD_ENCRYPTION_KEY=change-me-to-a-fernet-key

# ── Sentry ──
SENTRY_DSN=
SENTRY_TRACES_RATE=0.1
SENTRY_ENVIRONMENT=development

# ── CORS ──
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
